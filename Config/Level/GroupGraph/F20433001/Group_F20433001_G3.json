{
  "OnInitSequece": [
    {
      "TaskList": []
    }
  ],
  "OnStartSequece": [
    {
      "TaskList": [
        {
          "$type": "RPG.GameCore.WaitSecond",
          "WaitTime": {
            "IsDynamic": false,
            "FixedValue": {
              "Value": 10
            }
          }
        },
        {
          "$type": "RPG.GameCore.AdvClientChangePropState",
          "TargetType": {
            "$type": "RPG.GameCore.TargetFetchAdvPropEx",
            "FetchType": "SinglePropByPropID",
            "SinglePropID": {
              "GroupID": {
                "IsDynamic": false,
                "FixedValue": {
                  "Value": 3
                }
              },
              "ID": {
                "IsDynamic": false,
                "FixedValue": {
                  "Value": 300001
                }
              }
            }
          },
          "FromState": "Locked",
          "CanChangeServerProp": true
        }
      ]
    }
  ],
  "Type": "Group"
}