                    "$type": "RPG.GameCore.TargetFetchAdvPropEx"
                  },
                  "Name": {
                    "Value": "Default"
                  }
                },
                {
                  "$type": "RPG.GameCore.AdvSetColliderGroupState",
                  "TargetType": {
                    "$type": "RPG.GameCore.TargetFetchAdvPropEx"
                  },
                  "GroupName": "Close01"
                }
              ]
            },
            {
              "$type": "RPG.GameCore.PropStateCaseContainer",
