              "OnSuccess": [
                {
                  "$type": "RPG.GameCore.RemoveNavMeshState",
                  "TargetType": {
                    "$type": "RPG.GameCore.TargetFetchAdvPropEx"
                  }
                },
                {
                  "$type": "RPG.GameCore.AdvSetColliderGroupState",
                  "TargetType": {
                    "$type": "RPG.GameCore.TargetFetchAdvPropEx"
                  },
                  "GroupName": "Open01"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "OnStartSequece": [
