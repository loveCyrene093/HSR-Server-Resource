                  "$type": "RPG.GameCore.PropReqInteract",
                  "TargetType": {
                    "$type": "RPG.GameCore.TargetFetchAdvPropEx"
                  },
                  "InteractID": {
                    "IsDynamic": false,
                    "FixedValue": {
                      "Value": 1010
