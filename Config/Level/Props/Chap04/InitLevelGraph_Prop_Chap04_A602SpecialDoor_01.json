              "$type": "RPG.GameCore.PropStateCaseContainer",
              "OnSuccess": [
                {
                  "$type": "RPG.GameCore.AnimSetParameter",
                  "TargetType": {
                    "$type": "RPG.GameCore.TargetFetchAdvPropEx"
                  },
                  "ParameterName": "IsReady",
                  "ParameterType": "Bool",
                  "Value": {
                    "IsDynamic": false,
                    "FixedValue": {
                      "Value": 1
                    }
                  }
                }
              ]
            },
            {
              "$type": "RPG.GameCore.PropStateCaseContainer",
              "Case": "Open",
              "OnSuccess": [
                {
                  "$type": "RPG.GameCore.AnimSetParameter",
                  "TargetType": {
                    "$type": "RPG.GameCore.TargetFetchAdvPropEx"
                  },
                  "ParameterName": "IsReady",
                  "ParameterType": "Bool",
                  "Value": {
                    "IsDynamic": false,
                    "FixedValue": {
                      "Value": 1
                    }
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "OnStartSequece": [
    {
      "TaskList": [
