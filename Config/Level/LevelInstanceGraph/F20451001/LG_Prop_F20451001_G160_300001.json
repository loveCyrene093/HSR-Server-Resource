                  "SinglePropID": {
                    "GroupID": {
                      "IsDynamic": false,
                      "FixedValue": {
                        "Value": 160
                      }
                    },
                    "ID": {
                      "IsDynamic": false,
                      "FixedValue": {
                        "Value": 300002
                      }
                    }
                  }
                },
                "State": "Hidden"
              },
              "SuccessTaskList": [],
              "FailedTaskList": [
                {
                  "$type": "RPG.GameCore.SetEntityVisible",
                  "TargetType": {
                    "$type": "RPG.GameCore.TargetFetchAdvPropEx"
                  },
                  "MuteTriggerWhenInvisible": true
                },
                {
                  "$type": "RPG.GameCore.PropEnableCollider",
                  "TargetType": {
                    "$type": "RPG.GameCore.TargetFetchAdvPropEx"
                  }
                },
                {
                  "$type": "RPG.GameCore.EnableBillboard",
